{
  "name": "minio-parquet-sink",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "3",
    "topics": "postgres.public.orders",
    "s3.region": "us-east-1",
    "s3.bucket.name": "raw-events",
    "s3.part.size": "67108864",
    "store.url": "http://minio1:9000",
    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "aws.access.key.id": "minioadmin",
    "aws.secret.access.key": "minioadmin123",
    "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",
    "parquet.codec": "snappy",
    "flush.size": "50000",
    "rotate.interval.ms": "300000",
    "rotate.schedule.interval.ms": "600000",
    "partitioner.class": "io.confluent.connect.storage.partitioner.TimeBasedPartitioner",
    "path.format": "'year'=YYYY/'month'=MM/'day'=dd",
    "partition.duration.ms": "3600000",
    "locale": "en_US",
    "timezone": "UTC",
    "timestamp.extractor": "RecordField",
    "timestamp.field": "__source_ts_ms",
    "schema.compatibility": "FULL",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "dlq-minio-parquet",
    "errors.deadletterqueue.topic.replication.factor": "1",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true"
  }
}
